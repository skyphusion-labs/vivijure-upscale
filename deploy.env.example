# deploy.env -- keys and settings for ./deploy.sh (vivijure-upscale, video upscale).
# Copy this file to deploy.env, then fill it in. deploy.env is git-ignored; never commit it.

# ---- required ---------------------------------------------------------------

# Your RunPod API key. Get it at runpod.io -> Settings -> API Keys.
RUNPOD_API_KEY=

# The image to build and run. Point this at YOUR OWN registry (so you control the pushes).
# The default is our public image; change <you> to your own GitHub/registry user to publish your own.
IMAGE=ghcr.io/skyphusion-labs/vivijure-upscale:latest

# A name for the RunPod endpoint. Any label you like.
ENDPOINT_NAME=vivijure-video-upscale

# Which GPU(s) RunPod may run this on, comma-separated (first available is used).
# This job needs HARDWARE video encode (NVENC) and a few GB of VRAM, not a giant card. An Ada card
# like the L4 or L40S is the sweet spot; a Blackwell RTX PRO 6000 also works if Ada stock is thin.
# A faster card finishes in fewer billed seconds, so speed per dollar beats sticker price. Copy a GPU
# name exactly as RunPod lists it.
GPU_TYPE_IDS=NVIDIA L4,NVIDIA L40S,NVIDIA RTX PRO 6000 Blackwell Server Edition

# ---- optional (sensible defaults; uncomment to change) ----------------------

# Container disk in GB. The Real-ESRGAN weights are only a few MB, so 20 is plenty.
CONTAINER_DISK_GB=20

# Autoscaling. workersMin 0 = scale to zero = pay nothing when idle.
# WORKERS_MIN=0
# WORKERS_MAX=2
# IDLE_TIMEOUT=5
# EXECUTION_TIMEOUT_MS=600000

# Tuning knobs for the upscaler itself (passed to the endpoint). Defaults are good for most cards;
# lower UPSCALE_BATCH on a smaller card if you hit out-of-memory. See docs/deploy.md for what each does.
# MAX_OUTPUT_LONG_EDGE=3840
# FFMPEG_TIMEOUT=1200
# UPSCALE_BATCH=16
# UPSCALE_TILE=1024
# UPSCALE_FP16=1

# If your IMAGE is PRIVATE, RunPod needs a registry credential to pull it. Create one in the RunPod
# console (Settings -> Container Registry Auth) and put its id here. Leave blank for a PUBLIC image.
# CONTAINER_REGISTRY_AUTH_ID=

# Log in to your registry before pushing. Leave blank if you already ran 'docker login'.
# REGISTRY_USER=
# REGISTRY_TOKEN=

# R2 "finish-chain" mode: the endpoint reads the clip and writes the upscaled result straight to your
# R2 bucket by key. Set these to turn it on (the studio uses this mode). Leave blank to use only the
# presigned-URL mode, where the studio hands the endpoint temporary links instead.
# R2_ENDPOINT_URL=
# R2_BUCKET=vivijure
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# Skip flags for re-runs. SKIP_BUILD=1 reuses an already-pushed image; SKIP_ENDPOINT=1 stops after push.
# SKIP_BUILD=0
# SKIP_ENDPOINT=0

# Printed at the end to remind you how to wire this into the studio. Do not need to change it.
STUDIO_ENV_HINT="In your vivijure Studio deploy.env set VIDEO_UPSCALE_RUNPOD_ENDPOINT_ID to the endpoint id above, keep VIVIJURE_PROFILE=full, and re-run the studio ./deploy.sh. This turns on the finish-upscale module. See the studio docs/opt-in-tiers.md (finish-upscale)."
